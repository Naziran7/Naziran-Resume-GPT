
# Application Environment (development, production, test)
ENVIRONMENT=development

# Database Settings (Local Docker defaults)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Nazi
POSTGRES_DB=nazirangpt
POSTGRES_SERVER=YOUR_DATABASE_URL
POSTGRES_PORT=5433

# Security Keys
# Run "openssl rand -hex 32" to generate a secure secret key in production
SECRET_KEY=YOUR_SECRET_KEY

# Google Gemini LLM API Key (For Phase 2 RAG chatbot and advanced resume parsing)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Sentry Monitoring DSN (Optional)
SENTRY_DSN=
